-box;width: 70%;margin: auto;transform: rotate(-5deg)\" data-width=\"65%\">\n            <section class=\"assistant\" style=\"box-sizing:border-box;width: 100%;height: 1px;background: linear-gradient(to left,#BCBFBF 0%,rgba(254,254,254,0) 70%);\" data-width=\"100%\"></section>\n            <section style=\"display: flex;\">\n                <section style=\"display: flex;margin: 0 0 -8px 8px;\">\n                    <section class=\"assistant\" style=\"box-sizing:border-box;width: 1px;height: 100%;background: linear-gradient(to top,#BCBFBF 0%,rgba(254,254,254,0) 70%);\"></section>\n                </section>\n                <section style=\"margin: 10px;flex: 1;\">\n                    <section style=\"box-sizing:border-box;width: 100%;\" data-width=\"100%\">\n                        <img style=\"box-sizing:border-box;width: 100%; display: block;\" src=\"https://img.wyc520.com.cn/data/attachment/forum/202212/07/222430sl9f7fes96z6ris2.jpg\" data-ratio=\"0.6699751861042184\" data-w=\"403\" hm_fix=\"332:489\" data-width=\"100%\"/>\n                    </section>\n                </section>\n                <section style=\"display: flex;margin: -8px 8px 0 0;\">\n                    <section class=\"assistant\" style=\"box-sizing:border-box;width: 1px;height: 100%;background: linear-gradient(to bottom,#BCBFBF 0%,rgba(254,254,254,0) 70%);\"></section>\n                </section>\n            </section>\n            <section class=\"assistant\" style=\"box-sizing:border-box;width: 100%;height: 1px;background: linear-gradient(to right,#BCBFBF 0%,rgba(254,254,254,0) 70%);\" data-width=\"100%\"></section>\n        </section>\n    </section>\n</section>\n<br>\n<section style=\"text-align: center;margin: 10px auto;\">\n <section style=\"display: flex;justify-content: center;align-items: center;\">\n<section style=\"transform:rotate(0deg);box-sizing:border-box;border:1px solid #A6B78A;color:#9CAC80;border-radius:100% ;display: inline-block;padding:4px;margin-left: 6px;background: #EDF0D4;\">\n<section class=\"135brush\" data-brushtype=\"text\" style=\"box-sizing:border-box;width:40px;height:40px;color:#A6B78A;border-radius:100%;font-size:22px;line-height:40px;text-align: center;\">\n <strong>温</strong>\n</section>\n</section>\n<section style=\"transform:rotate(0deg);box-sizing:border-box;border:1px solid #A6B78A;color:#A6B78A;border-radius:100% ;display: inline-block;padding:4px;margin-left: 6px;background: #A6B78A;margin-left: -6px;\">\n<section class=\"135brush\" data-brushtype=\"text\" style=\"box-sizing:border-box;width:40px;height:40px;background:#A6B78A;color:#fff;border-radius:100%;font-size:22px;line-height:40px;text-align: center;\">\n <strong>情</strong>\n</section>\n</section></section></section>\n<section class=\"135brush\" data-brushtype=\"text\" style=\"font-size: 14px;line-height: 2.8em;color: #638264;text-align: center;\">作曲｜钱雷　歌唱｜黄琦珊</section></section>\n</section>\n<span id=\"more\"></span> \n<section style=\"text-align:left; line-height: 1.8em; letter-spacing: 1.5px; margin-right: 0px; margin-left: 240px;\">\n<span style=\"color: #638264; font-family: 微软雅黑, Microsoft YaHei; font-size: 15px;\">\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n亲爱的孩子\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我不知道自己做得够好吗\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我是第一次做妈妈\n<!--more-->\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n尽管岁月已吹白我的头发\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n送你上学第一天\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n要你勇敢我却哭了\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n后来你每回离家挥手说走啦\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n当告别已变得轻松\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n可我的心还会空\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n亲爱的妈妈\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我不知道自己做得够好吗\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我是第一次做女儿\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n可也是第一次来做我\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n人长大不轻松\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我后来才知道\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n孩子会穿过大雨\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n去懂人间的道理\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我只能唠叨因为我已帮不上你了\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n早上吃饭了吗\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n按时睡觉了吗\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n原谅我只懂这样参与你生活\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n放手如果是一门功课\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n妈妈一生没考过\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n没有按时吃饭\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n忙碌不是我的错\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n如果让你知道却会令我很愧疚\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n你的嘘寒问暖我知道是为我好的\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n但又让我觉得我不曾被信任着\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n请放心让我前往属于我的人生啊\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n你那么勇敢善良我\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n很像你就不怕\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我知道全知道\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n可是我心疼啊\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我希望你被爱着\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我希望你要快乐\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n我希望我的双手可以为你挡着风\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n但有件事我非常确定\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n你是最好的女儿 请相信自己\n<section style=\"width:80%; border-top:dashed 1px #638264;margin-right: 0px; margin-left: -80px;\"></section>\n<br>\n</section></section></section></section></section>\n<section class=\"_editor\" style=\"margin: 1px auto;width:641PX;\">\n<section style=\"background-image: url('https://img.wyc520.com.cn/data/attachment/forum/202205/03/185750xyy38w00wjweryw5.png'); background-position: 0% 0%; background-repeat: no-repeat; box-sizing: border-box; text-align: center;background-size:100%;margin-bottom: 10px auto;\">\n<br/><br/><br/><br/><br/><br/><br/><br/>\n</div>\n<audio style=\"width:0px;height:0px;\" controls=\"controls\" autoplay=\"autoplay\" loop=\"loop\" src=\"http://music.163.com/song/media/outer/url?id=2016388265.mp3\" type=\"audio/mpeg\"></audio> \n</body>\n</html>\n","categories":[{"name":"music","slug":"music","count":3,"path":"api/categories/music.json"}],"tags":[{"name":"music","slug":"music","count":2,"path":"api/tags/music.json"}]}