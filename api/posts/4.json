{"total":127,"pageSize":10,"pageCount":13,"data":[{"title":"【087-091】第五章 流程控制-while和do while循环","slug":"JS007","date":"2023-06-25T00:27:59.000Z","updated":"2023-06-26T23:22:45.438Z","comments":true,"path":"api/articles/JS007.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>while循环</title>\n    <script>\n      // 1.while循环语法结构   while 当...的时候\n      // while(条件表达式) {\n      //       //循环体\n      // }\n      // 2.执行思路 当条件表达式为true 则执行循环体 否则退出循环\n      // 3.代码验证\n      // var num = 1;\n      // while (num <= 100) {\n      //    console.log('你好吗')\n      //    num++;\n      //  }\n      // 4.里面也该有计数器 初始化变量\n      // 5.里面也该有操作表达式 完成计数器的更新 防止死循环\n      // 打印人的一生\n      // var i = 1;\n      // while (i <= 100) {\n      //  console.log('这个人今年'+i+'岁了')\n      //  i++;\n      // }\n      // 2.计算1-计算1-100之间所有整数的和\n      // var sum = 0;\n      // var j = 1;\n      // while (j <= 100) {\n      //   sum += j;\n      //   j++;\n      // }\n      // console.log(sum);\n      // 3. 弹出一个提示框, 你好吗 如果输入我很好 就提示结束 否则一直询问\n      // 思路:\n      // 1) 弹出输入框，要求用户输入\n      // 2) 判断条件比较复杂,使用while循环\n      // 3) while循环语句中的条件表达式只要输入的不是我很好,就会一直循环\n      // var message = prompt('你好吗');\n      // while (message !== '我很好') {\n      //   message = prompt('你好吗');\n      // } \n      // alert('我也很好');\n      // 1. do while循环 语法结构\n      // do {\n      //   // 循环体\n      // } while (条件表达式)\n      // 2. 执行思路 跟while不同在于 do while 先执行一次循环体 再判断条件 如果条件表达式结果为真,则继续执行循环体,否则退出循环\n      // 3.代码验证\n      var i = 1;\n      do {\n        console.log('how are you');\n        i++;\n      } while (i <= 100)\n      // 打印人的一生\n      var i = 1;\n      do {\n        console.log('这个人今年'+i+'岁了');\n        i++;\n      } while(i <= 100)\n      // 1-100的整数和\n      var sum = 0;\n      var j = 1;\n      do {\n        sum += j;\n        j++;\n      } while(j <= 100)\n      console.log(sum);\n      // 弹出一个输入框 你好吗 回答我很好 \n      // do {\n      //   var message = prompt('你好吗');\n      // } while(message !== '我很好')\n      // alert('我也很好');\n    </script>  \n</head>\n<body>\n    <h3>4. while和do while循环</h3>","keywords":null,"cover":null,"content":null,"text":"                while循环          // 1.while循环语法结构   while 当...的时候      // while(条件表达式) {      //       //循环体      // }      // 2.执行思路 当条件表达式","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【069-086】第五章 流程控制-for循环","slug":"JS006","date":"2023-06-24T03:27:59.000Z","updated":"2023-06-26T23:22:35.902Z","comments":true,"path":"api/articles/JS006.json","excerpt":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<title>流程控制-分支</title>\n<!DOCTYPE html>\n<html>\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n<title>流程控制-循环</title>\n<script>\n     // 1. for 重复执行某些代码,通常跟计数有关系\n     // 2. for语法结构\n     // for(初始化变量;变量表达式;操作表达式)  {\n        //循环体;\n     //} \n     // 3. 初始化变量 就是用var声明的一个普通变量 通常用于作为计数器\n     // 4. 条件表达式 就是用来决定每一次循环是否继续执行 就是终止的条件\n     // 5. 操作表达式 是每次循环最后执行的代码 经常用于我们计数器变量进行更新(递增或递减)  \n     // 6. 代码体验 我们重复打印100句 hello\n     //for (var i = 1; i <= 100; i++) {\n        //console.log('hello');\n     //}\n     // 学生成绩\n     // var num = prompt('请输入班级的总人数:'); //num班级总人数\n     // var sum = 0;//求和的变量\n     // var average = 0;//求平均值的变量\n     // for (var i = 1; i <= num; i++) {\n     // var score = prompt('请您输入第'+ i +'个学生成绩')\n     // 因为从prompt取过来的数据是字符串型的需要转换为数字型\n     // sum = sum + parseFloat(score);\n     // }\n     // average = sum / num;\n     // alert('班级总成绩是:'+ sum);\n     // alert('班级平均成绩是:'+ average);\n     // 一行打印5颗星星\n     // console.log('⭐️⭐️⭐️⭐️⭐️');\n     // for (var i = 1; i <= 5; i++) {\n     // console.log('⭐️');\n     // }\n     // var str = '';\n     // for (var i = 1; i <= 5; i++) {\n     //  str = str + '⭐️';\n     // }\n     // console.log(str);\n     // var num = prompt('请输入星星的个数');\n     // var str = '';\n     // for (var i = 1; i <= num; i++) {\n     //  str = str + \"⭐️\";\n     // }\n     // console.log(str);\n     // 1.双重for循环结构\n     //   for(外层的初始化变量;外层的条件表达式;外层的操作表达式) {\n     //        for(内层的初始化变量;内层的条件表达式;内层的操作表达式) {\n     //          //执行语句;\n     //       }\n     // }\n     // 2.可以把里面的循环看作是外层循环的语句\n     // 3.外层循环执行一次,里面的循环执行全部\n     // 4.代码验证\n     // for (var i = 1; i <= 3; i++) {\n     //  console.log('这是外层循环第'+i+'次');\n     //  for (var j = 1; j <= 3; j++ ) {\n     //    console.log('这是里层的循环第'+ j + '次');\n     //  }\n     // }\n     // 打印10行5列星星\n     // 核心\n     // 1. 内存循环负责一行打印5个星星\n     // 2. 外层循环负责打印10行\n     // var str = '';\n     // for (var i = 1; i <=10; i++) {\n     //  for (var j = 1; j <= 5; j++) {\n     //     str = str + \"⭐️\";\n     // }\n     // 如果一行打印完5个星星就要另起一行 加 \\n\n     // str = str + '\\n';\n     // }\n     // console.log(str);    \n     // 打印n行n列\n     // var rows = prompt('请您输入行数');\n     // var cols = prompt('请您输入列数');\n     // var str = '';\n     // for (var i = 1; i <= rows; i++) {\n     //   for (var j = 1; j <= cols; j++) {\n     //    str = str + '⭐️';\n     // }\n     //    str = str + '\\n';\n     // }\n     // console.log(str);\n     // 课堂案例2-打印倒三角形\n     // var str = '';\n     // for (i = 1; i <= 10; i++) {\n     //   for (j = i; j <= 10; j++) {\n     //    str = str + '⭐️';\n     // }\n     // str += '\\n';\n     // }\n     // console.log(str);\n     // 正三角形\n     //  var str = '';\n     //  for (i = 1; i <= 10; i++) {\n     //  for (j = 1; j <= i; j++) {\n     //   str = str + '⭐️';\n     // }\n     // str += '\\n';\n     // }\n     // console.log(str);\n    // 课堂案例3 九九乘法表\n    var str = '';\n    for (var i = 1; i <= 9; i++) {\n      for (var j = 1; j <= i; j++) {\n         // 1 × 2 = 2\n         // str = str + '⭐️';\n         str += j + '×' + i + '=' + j * i +'\\t';\n      }\n      str = '\\n';\n    }\n    console.log(str);\n</script>\n</head>\n<body>        \n<h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"流程控制-分支流程控制-循环     // 1. for 重复执行某些代码,通常跟计数有关系     // 2. for语法结构     // for(初始化变量;变量表达式;操作表达式)  {        //循环体;     //}      // 3. 初始化变量 就是用","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【风花日记】 风花说","slug":"ssn","date":"2023-06-22T04:22:27.000Z","updated":"2023-06-22T10:37:12.001Z","comments":true,"path":"api/articles/ssn.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  <title>ssn</title>\n  </style>\n</head>\n<body>\n  <p align=\"center\" color=\"black\">\n    <a href=\"https://windflower2022.github.io/html/css/sjz/sjz1.html\" target=\"_blank\">点击全屏</a>\n  </p>","keywords":null,"cover":null,"content":null,"text":"        ssn        点击全屏        <br>    ","link":"","raw":null,"photos":[],"categories":[{"name":"日记","slug":"日记","count":1,"path":"api/categories/日记.json"}],"tags":[]},{"title":"【风花音画】 音画浏览","slug":"yhll","date":"2023-06-18T03:07:27.000Z","updated":"2023-06-18T07:08:53.895Z","comments":true,"path":"api/articles/yhll.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  <title>yhll</title>\n  </style>\n</head>\n<body>\n  <p align=\"center\" color=\"black\">\n    <a href=\"https://windflower2022.github.io/html/convert/button/yhll.html\" target=\"_blank\">点击全屏</a>\n  </p>","keywords":null,"cover":null,"content":null,"text":"        yhll        点击全屏        <br><br><br><br><br><br>        ","link":"","raw":null,"photos":[],"categories":[{"name":"音画","slug":"音画","count":40,"path":"api/categories/音画.json"}],"tags":[]},{"title":"【055-068】第五章 流程控制-分支","slug":"JS005","date":"2023-06-16T03:27:59.000Z","updated":"2023-06-25T04:50:09.520Z","comments":true,"path":"api/articles/JS005.json","excerpt":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<title>流程控制-分支</title>\n!--more-->\n<script>\n   //1. if的语法结构 如果if\n   //if (条件表达式) {\n    //执行语句;\n   //}\n   //2. 执行思路 如果if里面的条件表达式结果为真true 则执行大括号里面的语句 \n   //如果为假，则不执行大括号里面的语句 则执行if语句后面的代码\n   //3. 代码体验\n   //if (3 > 5) {\n    //alert('沙漠骆驼');\n   //} //不执行\n\n<p>   &#x2F;&#x2F;if (6 &gt; 5) {<br>    &#x2F;&#x2F;alert(‘沙漠骆驼’);<br>   &#x2F;&#x2F;} &#x2F;&#x2F;执行<br>    &#x2F;&#x2F; 弹出prompt输入框,用户输入年龄,程序把这个值取过来保存到变量中<br>    &#x2F;&#x2F;使用if语句来判断年龄,如果年龄大于18就执行if大括号里面的输出语句<br>    &#x2F;&#x2F;var age &#x3D; prompt(‘请输入您的年龄’);<br>    &#x2F;&#x2F;if (age &gt;&#x3D; 18) {<br>        &#x2F;&#x2F;alert(‘我想带你去网吧’);<br>    &#x2F;&#x2F;} </p>\n<pre><code>//4. 使用if else 条件表达句为真，则执行语句1，为假，则执行语句2\n//if (条件表达式1) &#123;\n    //执行语句1\n//&#125;  else &#123;\n    //执行语句2\n//&#125;\n\n//5. if里面的语句1和else里面的语句2最终只能有一个语句执行 2选1\n//6. else后面直接跟大括号，没有小括号\n//var age = prompt(&#39;请输入您的年龄&#39;);\n//if (age &gt;= 18) &#123;\n//    alert(&#39;我想带你去网吧&#39;);\n//&#125; else &#123;\n//    alert(&#39;回家去&#39;);\n//&#125;\n\n//var year = prompt(&#39;请您输入年份&#39;);\n//if (year % 4 == 0 &amp;&amp; year % 100 != 0 || year % 400 == 0) &#123;\n    //alert(&#39;闰年&#39;);\n//&#125; else &#123;\n    //alert(&#39;平年&#39;);\n//&#125;\n\n//var name = prompt(&#39;请输入姓名&#39;);\n//if (name = &#39;刘德华&#39;) &#123;\n//    alert(&#39;恭喜你中了5块&#39;);\n//&#125; else &#123;\n//    alert(&#39;谢谢参与&#39;);//为什么这个不对呢\n//&#125;\n\n//1. 多分支语句 就是利用多个条件来选择不同的语句执行 得到不同的结果 多选1的过程\n//2. if else if 多分支语句\n//3. 语法规范\n //if (条件表达1) &#123;\n    //语句1;\n //&#125; else if (条件表达式2) &#123;\n    //语句2;\n //&#125; else if (条件表达式3) &#123;\n    //语句3;\n     //......\n //&#125; else &#123;\n    // 最后的语句；\n //&#125; \n//4. 执行思路\n//如果条件表达式1满足，则执行语句1,如果不满足，就2，以此类推，如果都不成立，则执行else里面的语句\n//多分支语句还是多选1 最后只能一个语句执行\n//else if 里面的条件理论上是可以任意多个的\n//else if 中间有个空格\n//案例 成绩 \n//伪代码 按照从大到小的顺序\n//var score = prompt(&#39;请您的分数&#39;);\n //if (score &gt;= 90) &#123;\n    //alert(&#39;A&#39;);\n //&#125; else if(score &gt;= 80) &#123;\n    //alert(&#39;B&#39;);\n //&#125; else if (score &gt;= 70) &#123;\n    //alert(&#39;C&#39;);\n //&#125; else if (score &gt;= 60) &#123;\n    //alert(&#39;D&#39;);\n //&#125; else &#123;\n    //alert(&#39;E&#39;);\n //&#125; \n // 1. 由三元运算符组成式子称为三元表达式,可看作是简化版的if else\n // 2. ++num 一元 3+5 二元 ?: 三元表达\n // 3. 语法结构\n // 条件表达式 ？ 表达式1 ： 表达式2;\n // 4 执行思路.\n // 如果条件表达式结果为真 则返回 表达式1，为假，则返回表达式2\n // 5. 代码体验\n //var num = 10;\n //var result = num &gt; 5 ? &#39;是的&#39; : &#39;不是的&#39;; // 我们知result\n //console.log(result);\n // if (num &gt; 5) &#123;\n //     result = &#39;是的&#39;;\n // &#125; else &#123;\n //     result = &#39;不是的&#39;;\n // &#125;\n //数字补0,时间思路:\n // 1) 用户输入0-59之间的一个数字\n // 2) 如果数字小于10,则在这个数字前面补0,(加0)否则,不做操作\n // 3) 用一个变量接受这个返回值,输出\n var time = prompt(&#39;请~59之间的一个数字&#39;);\n // 三元表达式 条件表达式 ？表达式1 ： 表达式2 ;\n //var result = time &lt; 10 ? &#39;0&#39; + time : time ; //表达式有返回值 把它赋值给变量result\n //alert(result); //输出变量\n // switch语句\n // 1. switch 语句也是多分支语句 也可以实现多选1\n // 2. 语法结构 switch 转换、开关 case 小例子或选项的意思\n // switch (条件表达式) &#123;\n //      case value1:\n //          执行语句1;\n //           break;\n //      case value2:\n //          执行语句2;;\n //          break  \n //          ...\n //          default:\n //              执行最后的语句;\n // &#125;\n // 3. 执行思路 利用表达式的值和case后面的选项值相匹配 如果匹配上 就执行case里面的句子 如果都没有匹配上 那么执行default 里面的语句\n // 4. 代码验证\n //switch (2) &#123;\n    //case 1:\n        //console.log(&#39;这是1&#39;);\n        //break;\n    //case 2:\n        //console.log(&#39;这是2&#39;);\n        //break;\n    //case 3:\n        //console.log(&#39;这是3&#39;);\n    //default:\n        //console.log(&#39;没有匹配结果&#39;);\n //&#125; \n// 案例: 水果价格\n//var fruit = prompt(&#39;请输入水果名称&#39;);\n//switch (fruit) &#123;\n    //case &#39;香蕉&#39;:\n    //console.log(&#39;3元&#39;);\n    //break;\n    //case &#39;苹果&#39;:\n    //console.log(&#39;5元&#39;);\n    //break;\n    //default:\n        //console.log(&#39;没有此水果&#39;) \n//&#125; \n  \n</code></pre>\n<p></script>    </p>\n</head>\n<body>    \n<h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"流程控制-分支!--more-->   //1. if的语法结构 如果if   //if (条件表达式) {    //执行语句;   //}   //2. 执行思路 如果if里面的条件表达式结果为真true 则执行大括号里面的语句    //如果为假，则不执行大括号里面的语句 ","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【041-054】第四章 运算符","slug":"JS004","date":"2023-06-15T01:41:59.000Z","updated":"2023-06-25T04:48:27.750Z","comments":true,"path":"api/articles/JS004.json","excerpt":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<title>运算符</title>\n<script>\n   console.log(1 + 1);//2\n   console.log(1 - 1);//0\n   console.log(1 * 1);//1\n   console.log(1 / 1);//1\n   // 1. %取余(取模)\n   console.log(4 % 2);//0\n   console.log(5 % 3);//2\n   console.log(3 % 5);//3\n   //浮点数 算数运算里面会有问题 尽量避免用浮点数直接参与运算\n   console.log(0.1 + 0.2); // 0.30000000000000004\n   console.log(0.07 * 100); // 7.000000000000001\n   // 3. 我们不能直接拿着浮点数来进行比较 是否相等\n   var num = 0.1 + 0.2;\n   console.log(num == 0.3); //false\n   // 表达式 \n   console.log(1 + 1); //2就是返回值\n   // 在我们程序里面 2 = 1 + 1 把我们的右边表达式计算完毕把返回值给左边\n   var num = 1 + 1; \n   //1. 想要一个变量自己加1\n   var num = 1;\n   num = num + 1;//++num\n   console.log(num); //2\n   //2. 前置递增运算符 ++写在变量的前面\n   var age = 10;\n   ++age; //类似于age = age + 1\n   console.log(age);\n   //3. 前置递增运算符\n   var p = 10;\n   console.log(++p + 10);//21\n   //4. 后置递增或递减运算符\n   var num = 10;\n   num++; //num = num + 1 ++num;\n   console.log(num);\n   // 前置递增和后置递增如果单独使用 效果一样\n   // 后置递增 口诀: 先返回原值 后自加1\n   var age = 10;\n   console.log(age++ + 10); // 20\n   //小练习\n   var a = 10;\n   ++a; //++a 11  a = 11\n   var b = ++a + 2; // a = 12 ++a=12\n   console.log(b); // 14\n\n<p>   var c &#x3D; 10;<br>   c++;&#x2F;&#x2F; c++ 11 c &#x3D; 11<br>   var d &#x3D; c++ + 2; &#x2F;&#x2F; c++ &#x3D; 11  c &#x3D; 12<br>   console.log(d); &#x2F;&#x2F; 13</p>\n<p>   var e &#x3D; 10;<br>   var f &#x3D; e++ + ++e; &#x2F;&#x2F; 1. e++ &#x3D; 10 e&#x3D;11 2. e &#x3D; 12 ++e &#x3D; 12<br>   console.log(f); &#x2F;&#x2F; 22<br>   &#x2F;&#x2F;比较运算符<br>   console.log(3 &gt;&#x3D; 5); &#x2F;&#x2F;false<br>   console.log(2 &lt;&#x3D; 4); &#x2F;&#x2F;true<br>   &#x2F;&#x2F;1. 我们程序里面的等于符号是 &#x3D;&#x3D; 默认转换数据类型 会把字符串型的数据转换为数字型<br>   console.log(3 &#x3D;&#x3D; 5);&#x2F;&#x2F;false<br>   console.log(‘风飞花’ &#x3D;&#x3D; ‘叶画’);&#x2F;&#x2F;false<br>   console.log(18 &#x3D;&#x3D; 18);&#x2F;&#x2F;true<br>   console.log(18 &#x3D;&#x3D; ‘18’); &#x2F;&#x2F;true<br>   console.log(18 !&#x3D; 18); &#x2F;&#x2F;false<br>   &#x2F;&#x2F; 2. 我们程序里面有全等 一模一样 要求 两侧的值 还有数据类型完全一致才可以<br>   console.log(18 &#x3D;&#x3D;&#x3D; 18);<br>   console.log(18 &#x3D;&#x3D;&#x3D; ‘18’); &#x2F;&#x2F;false<br>   &#x2F;&#x2F; 逻辑与 两侧为true,结果为true,否则为false<br>   console.log(3 &gt; 5 &amp;&amp; 3 &gt; 2); &#x2F;&#x2F;false<br>   console.log(3 &lt; 5 &amp;&amp; 3 &gt; 2); &#x2F;&#x2F;true<br>   &#x2F;&#x2F; 逻辑或 || 两侧都为false,则为false 只要两侧有一个为true,则为true；<br>   console.log(3 &gt; 5 || 3 &gt; 2); &#x2F;&#x2F;false<br>   &#x2F;&#x2F; 逻辑非 not !<br>   console.log(!true); &#x2F;&#x2F;false<br>   &#x2F;&#x2F;小练习<br>   var num &#x3D; 7;<br>   var str &#x3D; ‘我爱你<del>中国</del>‘;<br>   console.log(num &gt; 5 &amp;&amp; str.length &gt;&#x3D; num); &#x2F;&#x2F;true<br>   console.log(num &lt; 5 &amp;&amp; str.length &gt;&#x3D; num); &#x2F;&#x2F;false<br>   console.log(!(num &lt; 10)); &#x2F;&#x2F;false<br>   console.log(!(num &lt; 10 || str.length &#x3D;&#x3D; num)); &#x2F;&#x2F;false<br>   &#x2F;&#x2F;逻辑与短路运算<br>   &#x2F;&#x2F;1. 用我们的布尔值参与的逻辑运算 true &amp;&amp; false &#x3D;&#x3D;false<br>   &#x2F;&#x2F;2. 123 &amp;&amp; 456 是值 或者是 表达式 参与逻辑运算？<br>   &#x2F;&#x2F;3. 逻辑与短路运算 如果表达式1 结果为真 则返回表达式2 如果表达式1为假 那么返回表达式1<br>   console.log(123 &amp;&amp; 456); &#x2F;&#x2F;456<br>   console.log(0 &amp;&amp; 456); &#x2F;&#x2F;0<br>   console.log(0 &amp;&amp; 1 + 2 &amp;&amp; 456 * 56789); &#x2F;&#x2F;0<br>   console.log(‘’ &amp; 1 + 2 &amp;&amp; 456 * 56789); &#x2F;&#x2F;‘’<br>   &#x2F;&#x2F;如果有空的或者否定的为假 其余是真的  0 ‘’ null undefined NaN<br>   &#x2F;&#x2F; 4. 逻辑或短路运算 如果表达式1 结果为真 则返回的是表达式1 如果表达式1 结果为假 则返回表达式2<br>    console.log(123 || 456); &#x2F;&#x2F;123<br>    console.log(123 || 456 || 456 + 123); &#x2F;&#x2F;123<br>    console.log(0 || 456 || 456 + 123); &#x2F;&#x2F;456<br>    &#x2F;&#x2F;逻辑中断很重要 它会影响到程序运行结果思密达<br>    console.log(123 || num++);&#x2F;&#x2F;123<br>    console.log(num);&#x2F;&#x2F;0<br>    &#x2F;&#x2F;赋值运算符<br>    var num &#x3D; 10;<br>    &#x2F;&#x2F; num &#x3D; num + 1; num++<br>    &#x2F;&#x2F; num &#x3D; num + 2; num +&#x3D; 2;<br>    num +&#x3D; 2;<br>    consolelog(num); &#x2F;&#x2F;12<br>    num +&#x3D; 5; &#x2F;&#x2F;相当于age &#x3D; age + 5;<br>    consolelog(num); &#x2F;&#x2F;15<br>    var age &#x3D; 2;<br>    age *&#x3D; 3;<br>    console(age);&#x2F;&#x2F;6<br></script> </p>\n</head>\n<body>    \n<h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"运算符   console.log(1 + 1);//2   console.log(1 - 1);//0   console.log(1 * 1);//1   console.log(1 / 1);//1   // 1. %取余(取模)   console.log(4 % 2)","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【020-040】第三章 数据","slug":"JS003","date":"2023-06-10T10:41:59.000Z","updated":"2023-06-25T04:46:25.824Z","comments":true,"path":"api/articles/JS003.json","excerpt":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<title>数据类型</title>\n<script>\n    //var num;//这里的num我们是不确定属于哪种数据类型\n    var num = 10;//num属于数字型\n    //js的变量数据类型是只有程序在运行过程中，根据等号右边的值来确定的\n    var str = 'pink'//str属于字符串型\n    //js时动态语言 变量的数据类型是可以变化的\n    var x = 10;//x是数字型\n    x = 'pink';//x是字符串型\n    var num = 10;//num属于数字型\n    var PI = 3.14 //PI数字型\n    //1. 八进制 0-7 我们程序里面数字前面加0表示八进制\n    var num1 = 010;\n    console.log(num1);// 010 八进制转换为 10 进制 就是 8\n    var num2 = 012;\n    console.log(num2);\n    //2. 16进制 0-9 a-f #ffffff 数字的前面加0x表示十六进制\n    var num3 = 0x9;\n    console.log(num3);\n    var num4 = 0xa;\n    console.log(num4);\n    //3. 数字的最大值\n    console.log(Number.MAX_VALUE);\n    //4. 数字的最小值\n    console.log(Number.MIN_VALUE);\n    //5. 无穷大\n    console.log(Number.MAX_VALUE * 2 );//Infinity\n    //6. 无穷小\n    console.log(-Number.MAX_VALUE* 2 );//-Infinity\n    //7. 非数字\n    console.log('pink老师' - 100);//NaN\n    // isNaN() 这个方法用来判断非数字 并且返回一个值 如果是数字返回的是false 如果不是数字，返回的是ture\n    //console.log(isNaN(12));//false\n    //console.log(isNaN('pink老师'));//true\n    //alert('I like you to be still \\n \"Do you have the same feeling? \" ')\n    //1. 检测获取字符串的长度 lenth\n    //var str = 'my name is andy';\n    //console.log(str.length);//15\n    //var strMsg = '应该制定一个学习计划';\n    //alert(strMsg.length);\n    //2. 字符串的拼接 + \n    console.log('风飞' + \"花起\");//字符串的 风飞花起\n    console.log('pink' + '18');\n    console.log('pink' + true);\n    console.log(12 + 12);//24\n    console.log('12' + 12);\n    //3. 字符串拼接的加强\n    console.log('pink老师'+18);//pink老师18\n    console.log('pink'+18+'岁');//pink老师18岁\n    var age = 18;\n    console.log('pink老师age岁');\n    // 我们变量不要写到字符串里面，是通过和字符串相连的方式实现的\n    console.log('pink老师'+ age + '岁');//pink老师18岁 \n    // 变量和字符串相连的口诀： 引引加加\n    console.log('pink老师'+age+'岁');\n    // 案例 程序交互三部曲\n    // 1. 弹出一个输入框(prompt),让用户输入年龄(用户输入)\n    // 2. 把用户输入的值用变量保存起来,把刚才输入的年龄与所要输出的字符串拼接(<b>程序内部处理</b>)\n    // 3. 使用alert语句弹出警示框(输出结果)\n    //var age = prompt('请输入您的年龄');\n    //var str = '您今年已经'+ age +'岁了';//内部处理\n    //alert(str);\n    //布尔型\n    var flag = true; //flag 布尔型 参与加法运算当作1\n    var flag1 = false; //flag1 布尔型 加法里当作0\n    console.log(flag + 1); // true  2\n    console.log(flag1 + 1); // false 1\n    //如果一个变量声明未赋值 就是undefined 未定义数据类型\n    var str;\n    console.log(str);\n    var variable = undefined;\n    console.log(variable + 'pink'); // underfinedpink\n    console.log(variable + 1);// NaN undefined 和数字相加 最后的结果是 NaN即not a number\n    // null 空值\n    var space = null;\n    console.log(space + 'pink'); // nullpink\n    console.log(space + 1); // 1\n    // 获取数据类型\n    var num = 10;\n    console.log(typeof num); // number\n    var str = 'pink';\n    console.log(typeof str); //string\n    var flag = true;\n    console.log(typeof flag); // blean\n    var vari = undefined;\n    console.log(typeof vari); // undefined\n    var timer = null;\n    console.log(typeof timer); // object\n    // prompt 取过来的值是 字符型的\n    var age = prompt('请输入您的年龄');\n    console.log(age);\n    console.log(typeof age);\n    // 据输出颜色也可判断什么类型\n    console.log(18);\n    console.log('18');\n    console.log(true);\n    console.log(undefined);\n    console.log(null);\n    // 转换字符串\n    // 1.把数字型转换成, 变量.toString()\n    var num = 10;\n    var str = num.toString();\n    console.log(str);\n    console.log(typeof str);\n    // 2.利用String() 把变量放入小括号里\n    console.log(String(num));\n    // 3.利用 + 拼接字符串的方法来实现\n    console.log(num + '1');\n    //转换为数字型\n    var age = prompt('请输入您的年龄');\n    console.log(age);\n    // 1. parseInt(变量) 可以把字符型的转换为数字型 得到的是整数\n    console.log(parseInt(age));\n    console.log(parseInt('3.94')); //3\n    console.log(parseInt('120px'));//120\n    console.log(parseInt('rem120px'));  //NaN\n    // 2. parseFloat(变量) 可以把字符型的转换为数字型 得到的是小数 浮点数\n    console.log(parseFloat('3.94')); //3.94\n    console.log(parseFloat('120px')); //120\n    console.log(parseFloat('rem120px'));  //NaN\n    // 3.利用Number(变量)\n    var str = '123';\n    console.log(Number(str));\n    console.log(Number('12'));//12\n    // 4. 利用了算数运算- * /\n    console.log('12'-0);//12\n    console.log('123'-'120');//3\n    console.log('123'*2);//246\n    console.log('123'-120);//3\n    console.log('123'*'2');//246\n    // 案例 计算年龄\n    //var year = prompt('请输入您的出生年份');\n    //var age = 2023 - year;//year取过来的是字符串型 但这是减法 有隐式转换\n    //alert('您今年已经'+ age +'岁了');\n    // 案例2 加法计算\n    //var num1 = prompt('请您输入第一个值');\n    //var num2 = prompt('请您输入第二个值');\n    //var result = parseFloat(num1) + parseFloat(num2);\n    //alert('您的结果是:' + result);\n    //转换为布尔值\n    console.log(Boolean('')); //false\n    console.log(Boolean(0));  //false\n    console.log(Boolean(NaN)); //false\n    console.log(Boolean(null)); //false\n    console.log(Boolean(undefined)); //false\n    console.log(Boolean('小白')); //true\n    console.log(Boolean(12)); //true\n</script>\n</head>\n<body>    \n<h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"数据类型    //var num;//这里的num我们是不确定属于哪种数据类型    var num = 10;//num属于数字型    //js的变量数据类型是只有程序在运行过程中，根据等号右边的值来确定的    var str = 'pink'//str属于字符串型   ","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【风花音画】很久很久以前","slug":"hjhjyq","date":"2023-06-08T13:21:27.000Z","updated":"2023-06-18T05:49:56.202Z","comments":true,"path":"api/articles/hjhjyq.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <title></title>\n  </head>\n  <body>\n  <p align=\"center\" color=\"black\">\n    <a href=\"https://windflower2022.github.io/html/img/hjhjyq.html\" target=\"_blank\">点击全屏</a>\n  </p>","keywords":null,"cover":null,"content":null,"text":"                点击全屏         <br><br><br><br><br><br><br><br><br><br>    ","link":"","raw":null,"photos":[],"categories":[{"name":"音画","slug":"音画","count":40,"path":"api/categories/音画.json"}],"tags":[]},{"title":"【风花音画】于无声处","slug":"ywsc","date":"2023-06-06T14:08:27.000Z","updated":"2023-06-18T06:04:01.756Z","comments":true,"path":"api/articles/ywsc.json","excerpt":"<!DOCTYPE html>\n<html>\n<head>\n <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  <title>waiting</title>\n  </style>\n</head>\n<body>\n  <p align=\"center\" color=\"black\">\n    <a href=\"https://windflower2022.github.io/html/bg/14.html\" target=\"_blank\">点击全屏</a>\n  </p>","keywords":null,"cover":null,"content":null,"text":"       waiting        点击全屏        <br><br><br><br><br><br>    ","link":"","raw":null,"photos":[],"categories":[{"name":"音画","slug":"音画","count":40,"path":"api/categories/音画.json"}],"tags":[]},{"title":"【011-019】第二章 变量","slug":"JS002","date":"2023-06-06T10:41:59.000Z","updated":"2023-06-25T04:47:25.305Z","comments":true,"path":"api/articles/JS002.json","excerpt":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<title>变量</title>","keywords":null,"cover":null,"content":null,"text":"变量      //1.声明了一个age的变量    var age;    //2.赋值，把这个值存入这个变量中    age = 18;    //3.输出结果    console.log(age);    //4.变量的初始化    //case1 声明多个变量    v","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]}]}