hotos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【140-142】第九章 预解析","slug":"JS012","date":"2023-07-06T00:08:59.000Z","updated":"2023-07-06T00:11:48.315Z","comments":true,"path":"api/articles/JS012.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>预解析</title>\n <script>\n      /* \n    // 1 问\n     console.log(); // 报错\n    // 2 问\n     console.log(num); // undefined\n     var num = 10;\n    // 3 问\n    fn(); // 写在上,下面均可\n    function fn() {\n        console.log(11); // 11\n    }\n    // 4问\n    var fun = function() {\n        console.log(22); // 22\n    }\n    fn(); // 不可以放最上面\n    */\n    </script>\n</head>\n<body>\n    <h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"                预解析       /*     // 1 问     console.log(); // 报错    // 2 问     console.log(num); // undefined     var num = 10;    // 3 问   ","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【131-139】第八章 作用域","slug":"JS011","date":"2023-07-04T23:15:59.000Z","updated":"2023-07-05T00:10:06.509Z","comments":true,"path":"api/articles/JS011.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>作用域</title>\n</head>\n<body>\n    <h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"                作用域    目标        能说出两种作用域    能区分全局变量和局部变量及特征    能说出如何在作用域链中查找变量的值    目录    作用域    变量的作用域    作用域链    作用域(es6)    代码的名字在某个范围内起","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【113-130】第七章 函数","slug":"JS010","date":"2023-07-02T14:55:59.000Z","updated":"2023-07-03T03:11:30.599Z","comments":true,"path":"api/articles/JS010.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Function</title>\n    <script>\n   /*     \n    // 1. 求1-100的累加和\n    var sum = 0;\n    for (var i = 1; i <= 100; i++) {\n        sum += i;\n    }\n    console.log(sum);\n/*\n    // 2. 求10-50的累加和\n    var sum = 0;\n    for (var i = 10; i <= 50; i++) {\n        sum += i;\n    }\n    console.log(sum);\n/*\n    // 3.函数\n    // 1) 声明函数\n    function getSum(num1,num2) {\n        var sum = 0;\n        for (var i = num1; i <= num2; i++) {\n            sum += i;\n        }\n        console.log(sum);\n    }\n    // 2）调用函数\n    getSum(1,100);\n    getSum(10,50);\n/*\n    function sayHi() {\n        console.log('hi');\n    }\n    sayHi('hi');\n    // 1. 利用函数求任意两个数的和\n    function getSum (num1,num2) {\n        console.log(num1 + num2);\n    }\n    getSum(1,3);\n    getSum(3,8);\n    // 2. 利用函数求任意两个数间的和\n    function getSums (num1,num2) {\n        var sum = 0;\n        for (var i = num1; i <= num2; i++) {\n           sum += i; \n        }\n        console.log(sum);\n    }\n    getSums(1,100);\n    getSums(1,10);\n    // 3. 形参和实参个数不匹配问题</h4>\n    function getSum(num1,num2) {\n        console.log(num1 + num2);\n    }\n    // 1. 如果个数一致 正常输出\n    getSum(1,2);\n    // 2. 如果实参多余形参个数 会取形参个数\n    getSum(1,2,3);\n    // 3. 如果实参小余形参个数 多余的定义为undefined 结果是NaN\n    getSum(1);\n/*\n    // 完善\n    // 1\n    function cook(aru) {\n        return(aru);\n    }\n    cook('大肘子'); // 写不写都可以\n    console.log(cook('大肘子'));\n    // 2\n    function getNum(num1,num2) {\n        return  num1 + num2 ;\n    }\n    console.log(getNum(1,2));\n    // 1. 利用函数求任意两个数的最大值\n    function getMax(num1,num2) {\n        // if(num1 > num2) {\n        //    return num1; \n        // } else {\n        //    return num2;\n        // }\n        return num1 > num2 ? num1 : num2; // 另一种三元表达式 :否则的意思\n    }\n    console.log(getMax(1,3));\n    console.log(getMax(11,8));\n    // 2.利用函数求任意一个数组中的最大值 [5,2,99,101,67,77]\n    function getArrMax(arr) {\n        var max = arr[0];\n        for (var i = 1; i <=arr.length; i++) {\n            if (arr[i] > max) {\n                max = arr[i];\n            }\n        }\n        return max;\n    }\n    // getArrMax([5,2,99,101,67,77]); //实参是一个数组送过去\n    // 在我们实现开发里面,我们常用一组变量来接收函数的返回结果 使用更简单\n    var re = getArrMax([5,2,99,101,67,77]);\n    var re1 = getArrMax([9,7,99,181,67,57]);\n    console.log(re);\n    console.log(re1);\n    // return终止函数</h4>\n    function getSum(num1,num2) {\n        return num1 + num2;\n        alert('我是不会被执行的哦')\n    }\n    console.log(getSum(1,2));\n    // return只能返回一个值\n    function fn(num1,num2) {\n        return num1,num2; //返回的结果是最后的值\n    }\n    console.log(fn(1,2));\n    // 我们求任意两个数的加减乘除结果;\n    function getResult(num1,num2) {\n        return [num1 + num2, num1 - num2, num1 * num2, num1 / num2];\n    }\n    var re = getResult(1,2);\n    console.log(re);\n    //如果函数有return,则返回return后面的值; 如果没有return, 则返回undefined\n    function fn1() {\n        return 666;\n    }\n    console.log(fn1());// 返回666\n    function fn2() {\n   /*     \n    }\n    console.log(fn2());\n    // arguments的使用 只有函数才有arguments对象 而且是每个函数都内置了这个arguments\n    function fn() {\n        console.log(arguments); // 里面存储了所有传递过来的实参\n        console.log(arguments.length);\n        console.log(arguments[2]);\n  /* \n    // 可按照数组方式遍历arguments\n        for (var i = 0; i < arguments.length; i++) {\n            console.log(arguments[i]);\n        }\n    }\n    fn(1,2,3);\n    fn(1,2,3,4,5);\n    //利用函数求任意两个数的最大值\n    function getMax() { // arguments = [1, 2, 3]\n        var max = arguments[0];\n        for (var i = 1; i < arguments.length; i++) {\n            if (arguments[i] > max) {\n                max = arguments[i];\n            }\n        }\n        return max;\n    }\n    console.log(getMax(1,2,3));\n    console.log(getMax(1,2,3,4,5));\n    console.log(getMax(11,2,34,444,5,100));\n    // 利用函数翻转任意数组 reverse 翻转\n    function reverse(arr) {\n        var newArr = [];\n        for (var i = arr.length - 1; i >= 0; i--) {\n            newArr[newArr.length] = arr[i];\n        }\n        return newArr;\n    }\n    var arr1 = reverse([1,3,4,6,9]);\n    console.log(arr1);\n    var arr2 = reverse(['red','pink','blue']);\n    console.log(arr2);\n    // 利用函数进行排序,冒泡排序\n    function sort(arr) {\n        for (var i = 0; i < arr.length - 1; i++) {\n            for (var j = 0; j < arr.length - i - 1; j++) {\n                if (arr[j] > arr[j + 1]) {\n                    var temp = arr[j];\n                    arr[j] = arr[j + 1];\n                    arr[j + 1] = temp;\n                }\n            }\n        }\n        return arr;\n    }  \n    var arr1 = sort([1,4,2,9]);\n    console.log(arr1);\n    var arr2 = sort([11,7,22,999]);\n    console.log(arr2);\n    // 判断闰年\n    function isRunYear(year) {\n        // 如果是闰年我们返回true 否则false\n        var flag = false;\n        if (year % 4 == 0 && year % 100 != 0 || year % 400 == 0) {\n            flag = true;\n        }\n        return flag;\n    }\n    console.log(isRunYear(2000));\n    console.log(isRunYear(1999));\n    //函数可以调用另外一个函数\n    function fn1() {\n        console.log(11);\n        fn2(); // 在fn1函数里面调用了 fn2函数\n    }\n    fn1();\n    function fn2() {\n        console.log(22); \n    } \n    看下面函数输出的结果是多少\n    function fn1() {\n        console.log(111);\n        fn2();\n        console.log('fn1');\n    }\n    function fn2() {\n        console.log(222);\n        console.log('fn2');\n    }\n    fn1();\n    // 用户输入年份 输出当年份2月份的天数\n    function backDay () {\n        var year = prompt('请您输入年份:');\n        if (isRunYear(year)) {// 调用函数需要加小括号\n        alert('当前年份是闰年2月份有29天');\n    } else {\n        alert('当前月份是平年2月份有28天');\n    }\n}\n    backDay();\n    // 判断是否为闰年的函数\n    function isRunYear(year) {\n        // 如果是闰年我们返回true 否则返回false\n        var flag = false;\n        if (year % 4 == 0 && year!= 0 || year % 400 == 0) {\n            flag = true;\n        }\n        return flag;\n    }\n    //函数的两种声明方式\n    1.利用函数关键字定义函数(命名函数,名字是fun)\n    function fn() {\n /*       \n    }\n    fn(); // fn是函数名\n    2. 函数表达式(匿名函数,没有函数名)\n    var 变量名 = function(aru) {};\n    var fun = function() {\n        console.log('我是函数表达式');\n        console.log(aru);\n    }\n    fun('pink老师'); \n    1) 在此fun是变量名，不是函数名\n    2) 函数表达式声明方式跟声明变量差不多,只不过变量里面是值,而函数表达式里面存的是函数\n    3) 函数表达式也可以进行传递参数 \n    */\n    </script>\n</head>\n<body>\n    <h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"                Function       /*         // 1. 求1-100的累加和    var sum = 0;    for (var i = 1; i <= 100; i++) {        sum += i;    }    cons","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【096-112】第六章 数组","slug":"JS009","date":"2023-06-29T01:20:59.000Z","updated":"2023-07-03T02:09:50.177Z","comments":true,"path":"api/articles/JS009.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>数组</title>\n    <script>\n   /* var arr1 = [1,2,'pink老师',true];\n    console.log(arr1[2]);\n    var arr2 = ['语文','数学','英语','政治','历史','地理'];\n    console.log(arr2[5]);\n    //遍历: 就是把数组中的每一个元素从头到尾访问一次\n    var arr = ['red','green','blue'];\n    for (var i = 0; i < 3; i++) {\n        console.log(arr[i]);\n    }\n    var arr1 = ['关羽','张飞','马超','赵云','黄忠','刘备','姜维'];\n    for (var i = 0; i < 7; i++) {\n        console.log(arr1[i]);\n    }\n    // 求和以及平均值\n    var sum = 0;\n    var arr3 = [2,6,1,7,4]; \n    var average = 0;\n        for (var i = 0; i < arr3.length; i++) {\n            sum += arr3[i]; // 我们加的是数组元素 arr[i] 不是计数器i\n        average = sum / arr3.length;\n    }\n        console.log(sum, average); //想要输出多少个变量,用逗号分隔即可\n/*\n     // 求最大值\n    var arr4 = [2,6,1,77,52,25,7];\n    var max = arr4[0];\n    for (var i = 1; i < arr4.length; i++) {\n        if (arr4[i] > max ) {\n            max = arr4[i];\n        }     \n    }\n    console.log('这个数组里面的最大值是：' + max);\n   // 数组中转换为字符串\n   var arr = ['red','green','blue','pink'];\n   var str = '';\n   var sep = '|';\n    for (var i = 0; i < arr.length; i++) {\n        str += arr[i] + sep;\n    }\n    console.log(str);\n    //4.1. 修改length长度\n    var arr = ['red','green','blue'];\n    console.log(arr.length);\n    arr.length = 5; //把我们数组的长度修改为5;里面应有5个元素\n    console.log(arr);\n    console.log(arr[3]); //undefined\n    console.log(arr[4]); //undefined 两个元素为空元素\n    //4.2 修改索引号\n    var arr1 = ['red','green','blue'];\n    arr1[3] = 'pink';\n    console.log(arr1);\n    arr1[4] = 'hotpink';\n    console.log(arr1);\n    arr1[0] = 'yellow'; //本身有元素，这样会替换原来的元素\n    console.log(arr1);\n    arr1= '有点意思';\n    console.log(arr1);\n    //4.3案例，追加数组\n    var arr = [];\n    for (var i = 0; i < 10; i++) {\n      // arr = i; 是错的 不要直接给数组名赋值 否则以前的元素都没了\n      arr[i] = i + 1;\n    }\n    console.log(arr);\n    //4.4案例，筛选数组\n    var arr = [2,0,6,1,77,0,52,0,25,7];\n    var arr1 = [];\n    var j = 0;\n    for (var i = 0; i < arr.length; i++) {\n       if (arr[i] >= 10) {\n        // 新数组应从0开始 依次递增\n        arr1[j] = arr[i];\n        j++;\n       }\n    }\n    console.log(arr1);\n    // 方法二\n    var arr = [2,0,6,1,77,0,52,0,25,7];\n    var arr1 = [];\n    // 刚开始arr1.length就是0\n    for (var i = 0; i < arr.length; i++) {\n       if (arr[i] >= 10) {\n        // 新数组应从0开始 依次递增\n        arr1[arr1.length] = arr[i];\n       }\n    }\n    console.log(arr1);\n    //将数组[2,0,6,1,77,0,25,7]中的0去掉后,形成一个不包含0的新数组\n    var arr = [2,0,6,1,77,0,25,7];\n    var newArr = [];\n    for (var i = 0; i < arr.length; i++) {\n        if (arr[i] != 0) {\n            newArr [newArr.length] = arr [i];\n        }\n    }\n    console.log(newArr);\n    // 翻转数组\n    var arr = ['red','green','blue','pink','purple'];\n    var newArr =[];\n    for (var i = arr.length-1; i >= 0; i--) {\n        newArr[newArr.length] = arr [i];\n    }\n    console.log(newArr);\n   // [5,4,3,2,1]变成[1,2,3,4,5]\n    var arr =  [5,4,3,2,1];\n    for (var i = 0; i <= arr.length - 1; i++) { // 外层循环趟数\n        for (var j = 0; j <= arr.length - i - 1; j++) { // 里层循环每趟交换次数\n        // 内部交换两个变量的值 前一个和后一个比较\n        if (arr[j] > arr [j + 1]) {\n           var temp = arr[j] ;\n            arr[j] = arr[j + 1];\n            arr [j + 1] = temp;\n        }\n/*\n        }\n/*\n    }\n    console.log(arr); \n    */\n    </script>\n</head>\n<body>\n    <h3>目标</h3>","keywords":null,"cover":null,"content":null,"text":"                数组       /* var arr1 = [1,2,'pink老师',true];    console.log(arr1[2]);    var arr2 = ['语文','数学','英语','政治','历史','地理'];    conso","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【092-095】第五章 流程控制-continue和break循环","slug":"JS008","date":"2023-06-27T01:20:59.000Z","updated":"2023-07-02T13:22:44.564Z","comments":true,"path":"api/articles/JS008.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Document</title>\n    <script>\n        //continue 关键字 退出本次(当前的循环) 继续执行剩余次数循环\n        for (var i = 1; i <= 5; i++) {\n           if (i == 3) {\n            continue;//只要遇见continue就退出本次循环 直接跳到i++\n           }\n           console.log('我正在吃第' + i + '个包子');\n        }\n        // 1~100间,除了能被7整除之外的整数和\n        for (i = 1; i <= 100; i++) {\n            if (i % 7 == 0) {\n                continue;\n            }\n            sum += i;\n        }\n        console.log(sum);\n        // break 立即退出循环\n        for (var i = 1; i <= 5; i++) {\n            if (i == 3) {\n                break;\n            }\n            console.log('我正在吃第' + i + '个包子')\n        }\n    </script>\n</head>\n<body>\n   <h3>continue</h3>:","keywords":null,"cover":null,"content":null,"text":"                Document            //continue 关键字 退出本次(当前的循环) 继续执行剩余次数循环        for (var i = 1; i <= 5; i++) {           if (i == 3) {     ","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]}]}