,"link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"title":"【155-186】第十一章 内置对象","slug":"JS014","date":"2023-07-30T08:44:00.000Z","updated":"2023-07-30T08:48:05.363Z","comments":true,"path":"api/articles/JS014.json","excerpt":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>内置对象</title>\n <script>  \n  /*var myMath = {\n    PI: 3.14592653,\n    max: function() {\n      var max = arguments[0];\n      for (var i = 1; i < arguments.length; i++) {\n        if (arguments[i] > max ) {\n          max = arguments[i];\n        }\n      }\n      return max;\n    },\n    min: function() {\n      var min = arguments[0];\n      for (var i = 1; i < arguments.length; i++) {\n        if (arguments[i] < min ) {\n          min = arguments[i];\n        }\n      }\n      return min;\n    }\n  }\n  console.log(myMath.PI);\n  console.log(myMath.max(1,3,9));\n  console.log(myMath.min(1,3,9));\n  \n<p>  function getRandom(min,max) {<br>    return Math.floor(Math.random() * (max - min + 1)) + min;<br>  }<br>  var random &#x3D; getRandom(1,10);<br>  while(true) { &#x2F;&#x2F; 死循环<br>     var num &#x3D; prompt(‘你来猜？ 输入1~10之间的一个数字’);<br>     if ( num &gt; random) {<br>        alert(‘你猜大了’);<br>     } else if ( num &lt; random) {<br>        alert(‘你猜小了’);<br>     } else {<br>        alert(‘你好帅哦,猜对了’);<br>        break; &#x2F;&#x2F; 退出整个循环 结束程序<br>     }</p>\n<p>  var date &#x3D; new Date(); &#x2F;&#x2F; 如果没给参数 则返回当前系统的当前时间<br>  console.log(date);<br>  var date1 &#x3D; new Date(2019,10,1);<br>  console.log(date1);<br>  var date2 &#x3D; new Date(‘2019&#x2F;10&#x2F;1 8:8:8’);<br>  console.log(date2);<br>  var date &#x3D; new Date();<br>    }<br>  var date &#x3D; new Date();<br>  console.log(date.getFullYear()); &#x2F;&#x2F; 返回当前日期的年<br>  console.log(date.getMonth() + 1); &#x2F;&#x2F; z返回月份小1个月 记得+1<br>  console.log(date.getDate()); &#x2F;&#x2F; 返回当前是几号<br>  console.log(date.getDay()); &#x2F;&#x2F; 返回当前星期几 星期天是0<br>  &#x2F;&#x2F; 2023年7月10日 星期一<br>  var year &#x3D; date.getFullYear();<br>  var month &#x3D; date.getMonth() + 1;<br>  var dates &#x3D; date.getDate();<br>  var arr &#x3D; [‘星期日’,’星期一’,’星期二’,’星期三’,’星期四’,’星期五’,’星期六’]<br>  var day &#x3D; date.getDay();<br>  console.log(‘今天是:’  + year + ‘年’ + month + ‘月’ + dates + ‘日’ + arr[day]);<br>  &#x2F;&#x2F; 格式化时分秒<br>  var date &#x3D; new Date();<br>  console.log(date.getHours());<br>  console.log(date.getMinutes());<br>  console.log(date.getSeconds());<br>  &#x2F;&#x2F; 封装一个函数返回当前的时分秒 格式: 08:08:08<br>  function getTime() {<br>  var time &#x3D; new Date();<br>  var h &#x3D; time.getHours();<br>  h &#x3D; h &lt; 10 ? ‘0’ + h : h;<br>  var m &#x3D; time.getMinutes();<br>  m &#x3D; m &lt; 10 ? ‘0’ + m : m;<br>  var s &#x3D; time.getSeconds();<br>  s &#x3D; s &lt; 10 ? ‘0’ + s : s;<br>  return h + ‘:’ + m + ‘:’ + s;<br>  }<br>  console.log(getTime());<br>  &#x2F;&#x2F; 1) 通过valueOf() getTime()都可获得<br>  var date &#x3D; new Date();<br>  console.log(date.valueOf());<br>  console.log(date.getTime());<br>  &#x2F;&#x2F; 2) 简单写法<br>  var date1 &#x3D; +new Date(); &#x2F;&#x2F;  +new Date()返回的就是总的毫秒数<br>  console.log(date1);<br>  &#x2F;&#x2F; 案例 倒计时<br>  function countDown(time) {<br>  var nowTime &#x3D; +new Date(); &#x2F;&#x2F; 返回的是当前时间总毫秒数<br>  var inputTime &#x3D; +new Date(time); &#x2F;&#x2F; 返回的是用户输入时间的总的毫秒数<br>  var times &#x3D; (inputTime - nowTime) &#x2F; 1000; &#x2F;&#x2F; time时剩余时间总的秒数<br>  var d &#x3D; parseInt(times &#x2F; 60 &#x2F; 60 &#x2F; 24);<br>  d &#x3D; d &lt; 10 ? ‘0’ + d : d;<br>  var h &#x3D; parseInt(times &#x2F; 60 &#x2F; 60 % 24); &#x2F;&#x2F;计算小时<br>  h &#x3D; h &lt; 10 ? ‘0’ + h : h;<br>  var m &#x3D; parseInt(times &#x2F; 60 % 60);    &#x2F;&#x2F;计算分数<br>  m &#x3D; m &lt; 10 ? ‘0’ + m : m;<br>  var s &#x3D; parseInt(times % 60);      &#x2F;&#x2F;计算当前秒数<br>  s &#x3D; s &lt; 10 ? ‘0’ + s : s;<br>  return d + ‘天’ + h + ‘时’ + m + ‘分’ + s + ‘秒’;<br>}<br>console.log(countDown(‘2023-8-1 00:00:00’));<br>var date &#x3D; new Date();<br>console.log(date);<br>&#x2F;&#x2F;1. push()在我们数组的末尾 添加一个或者多个数组元素<br>  var arr &#x3D; [1,2,3];<br>  &#x2F;&#x2F;arr.push(4,’pink’);<br>  console.log(arr.push(4,’pink’));<br>  console.log(arr);<br>  arr.unshift(‘red’,’purple’);<br>  console.log(arr);<br>  var arr &#x3D; [1500,1200,2000,2100,1800];<br>  var newArr &#x3D; [];<br>  for (var i &#x3D; 0; i &lt; arr.length; i++) {<br>    if (arr[i] &lt; 2000) {<br>      &#x2F;&#x2F;  newArr[newArr.length] &#x3D; arr[i];<br>      newArr.push(arr[i]);<br>    }<br>  }<br>  console.log(newArr);<br>  &#x2F;&#x2F; 1).翻转数组<br>  var arr &#x3D; [‘pink’,’red’,’blue’];<br>  arr.reverse();<br>  console.log(arr);<br>  &#x2F;&#x2F; 2) 数组排序(冒泡排序)<br>  var arr1 &#x3D; [13,4,7,1,77];<br>  arr1.sort(function(a,b){<br>   &#x2F;&#x2F; return a - b; 升序排列<br>   return b - a ; &#x2F;&#x2F;降序排列<br>  });<br>  console.log(arr1);<br>  5.5 数组索引的方法<br>  &#x2F;&#x2F;封装一个去重的函数unique<br>  function unique(arr) {<br>    var newArr &#x3D; [];<br>    for (var i &#x3D; 0; i &lt; arr.length; i++) {<br>      if (newArr.indexOf(arr[i]) &#x3D;&#x3D;&#x3D; -1) {<br>        newArr.push(arr[i]);<br>      }<br>    }<br>    return newArr;<br>  }<br>  &#x2F;&#x2F; var demo &#x3D; unique([‘c’,’a’,’z’,’a’,’x’,’a’,’x’,’c’,’b’]);<br>  var demo &#x3D; unique([‘blue’,’green’,’blue’]);<br>  console.log(demo);<br>  &#x2F;&#x2F; 数组转换为字符串<br>  &#x2F;&#x2F; 1) toString()将我们的数组转换为字符串<br>  var arr &#x3D; [1, 2, 3];<br>  console.log(arr.toString()); &#x2F;&#x2F; 1,2,3<br>  &#x2F;&#x2F; 2)join(分隔符)<br>  var arr1 &#x3D; [‘green’, ‘pink’, ‘blue’];<br>  console.log(arr1.join()); &#x2F;&#x2F; green, pink, blue<br>  console.log(arr1.join(‘-‘)); &#x2F;&#x2F; green-pink-blue<br>  console.log(arr1.join(‘&amp;’)); &#x2F;&#x2F; green&amp;pink&amp;blue<br>  &#x2F;&#x2F;字符串不可变 不要大量拼接字符串 会占内存空间<br>  var str &#x3D; “abcoefoxyozzopp”;<br>    var index &#x3D; str.indexOf(“o”);<br>    var num &#x3D; 0;<br>    &#x2F;&#x2F; console.log(index);<br>    while (index !&#x3D;&#x3D; -1) {<br>      console.log(index);<br>      num++;<br>      index &#x3D; str.indexOf(‘o’, index + 1);<br>    }<br>    console.log(‘o出现的次数是’ + num);</p>\n<pre><code>var str1 = [&#39;red&#39;,&#39;blue&#39;,&#39;red&#39;,&#39;green&#39;,&#39;pink&#39;,&#39;red&#39;];\nvar index1 = str1.indexOf(&#39;red&#39;);\nvar num1 = 0;\n//console.log(index1)\nwhile (index1 !== -1) &#123;\n  console.log(index1);\n  num1++;\n  index1 = str1.indexOf(&#39;red&#39;, index1 + 1);\n&#125;\nconsole.log(&#39;red出现的次数是 &#39; + num1);\n\nvar str = &#39;abcoefoxyozzopp&#39;;\nvar o = &#123;&#125;;\nfor (var i = 0; i &lt; str.length; i++) &#123;\n  var chars = str.charAt(i);\n  if (o[chars]) &#123;\n    o[chars]++;\n  &#125; else &#123;\n    o[chars] = 1;\n  &#125;\n&#125;\nconsole.log(o);\n</code></pre>\n<p>   &#x2F;&#x2F; 2.遍历对象<br>   var max &#x3D; 0;<br>   var ch &#x3D; ‘’;<br>   for (var k in o) {<br>    &#x2F;&#x2F; k 得到的是属性<br>    &#x2F;&#x2F; o[k] 得到的是属性值<br>    if (o[k] &gt; max) {<br>      max &#x3D; o[k];<br>      ch &#x3D; k;<br>    }<br>   }<br>   console.log(max);<br>   console.log(‘最多的字符是’ + ch);<br><em>&#x2F;<br>   var str1 &#x3D; ‘abcoefoxyozzopp’;<br>   while (str1.indexOf(‘o’) !&#x3D;&#x3D; -1) {<br>    str1 &#x3D; str1.replace(‘o’,’</em>‘);<br>   }<br>   console.log(str1);</p>\n<p>   var str2 &#x3D; ‘red, pink, blue’;<br>   console.log(str2.split(‘,’));<br>   var str3 &#x3D; ‘red&amp;pink&amp;blue’;<br>   console.log(str3.split(‘&amp;’));<br>  </script></p>\n</head>\n<body>\n    <h2>目标</h2>","keywords":null,"cover":null,"content":null,"text":"                内置对象     /*var myMath = {    PI: 3.14592653,    max: function() {      var max = arguments[0];      for (var i = 1; i < argu","link":"","raw":null,"photos":[],"categories":[{"name":"JS","slug":"JS","count":15,"path":"api/categories/JS.json"}],"tags":[]},{"t